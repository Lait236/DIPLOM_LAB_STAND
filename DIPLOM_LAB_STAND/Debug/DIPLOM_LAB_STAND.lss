void keypad_init(void)
{
	// настройка портов клавиатуры

	DDRA |= (1 << KEYPAD_COL1) | (1 << KEYPAD_COL2) | (1 << KEYPAD_COL3); // вывод PA0, PA1, PA2 устанавливаем на вход	- это столбцы клавиатуры
