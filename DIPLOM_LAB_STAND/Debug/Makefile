clean:
	-$(RM) $(OBJS_AS_ARGS) $(EXECUTABLES)  
	-$(RM) $(C_DEPS_AS_ARGS)   
	rm -rf "DIPLOM_LAB_STAND.elf" "DIPLOM_LAB_STAND.a" "DIPLOM_LAB_STAND.hex" "DIPLOM_LAB_STAND.lss" "DIPLOM_LAB_STAND.eep" "DIPLOM_LAB_STAND.map" "DIPLOM_LAB_STAND.srec" "DIPLOM_LAB_STAND.usersignatures"
	